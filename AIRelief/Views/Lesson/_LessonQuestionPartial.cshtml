@model Question

@{
    string category = ViewBag.Category as string ?? Model.Category ?? string.Empty;
    int currentIndex = ViewBag.CurrentIndex is int ci ? ci : 0;
    int totalQuestions = ViewBag.TotalQuestions is int tq ? tq : 6;
}

<div class="question-card" data-question-id="@Model.ID">

    <div class="lesson-category-bar mb-3">
        <span class="category-label badge bg-secondary fs-6">@category</span>
        <button type="button"
                class="btn btn-link btn-sm p-0 ms-2 category-info-btn"
                data-bs-toggle="modal"
                data-bs-target="#categoryInfoModal"
                data-category="@category">
            <i class="bi bi-info-circle"></i> What is this?
        </button>
    </div>

    @if (!string.IsNullOrEmpty(Model.MainText))
    {
        <div class="question-situation-box">
            <span class="question-box-label">Situation</span>
            <p class="question-text mb-0">@Model.MainText</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.QuestionText))
    {
        <div class="question-question-box">
            <span class="question-box-label">Question</span>
            <p class="question-heading mb-0">@Model.QuestionText</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Image))
    {
        <div class="question-image">
            <img src="~/images/QuestionImages/@Model.Image" alt="Question illustration" class="img-fluid" />
        </div>
    }

    <input type="hidden" name="questionId" value="@Model.ID" />

    <div class="answer-options">
        @{
            var opts = new[] { Model.Option1, Model.Option2, Model.Option3, Model.Option4, Model.Option5 };
            var lbls = new[] { "A", "B", "C", "D", "E" };
        }
        @for (int i = 0; i < opts.Length; i++)
        {
            if (!string.IsNullOrEmpty(opts[i]))
            {
                <button type="button" class="answer-option btn"
                        onclick="selectAnswer('@Html.Raw(Html.Encode(opts[i]))', this)">
                    <span class="answer-letter">@(lbls[i]):</span> @opts[i]
                </button>
            }
        }
    </div>
</div>

<script>
    window.currentQuestionId = @Model.ID;
    $('#question-container').data('question-id', @Model.ID);
</script>
