@model LessonSummaryViewModel
@inject IStringLocalizer<LessonLessonSummaryResource> L

@{
    ViewData["Title"] = L["PageTitle"].Value;
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {

            // ?? Session polar area chart ???????????????????????????????
            var sessionLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SessionResults.Select(r => r.Category).ToArray()));
            var sessionScores  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SessionResults.Select(r => r.ScorePercent).ToArray()));

            new Chart(document.getElementById('sessionChart'), {
                type: 'polarArea',
                data: {
                    labels: sessionLabels,
                    datasets: [{
                        label: 'Score % this lesson',
                        data: sessionScores,
                        backgroundColor: [
                            'rgba(100, 160, 255, 0.6)',
                            'rgba(255, 160, 100, 0.6)',
                            'rgba(100, 220, 160, 0.6)',
                            'rgba(220, 100, 180, 0.6)',
                            'rgba(255, 220, 80, 0.6)',
                            'rgba(140, 100, 255, 0.6)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: { r: { beginAtZero: true, max: 100, ticks: { stepSize: 20 } } },
                    plugins: { legend: { position: 'bottom' } }
                }
            });

            @if (Model.Statistics != null && Model.LessonsCompleted >= 2)
            {
                <text>
                // ?? Overall polar area chart ??????????????????????????
                var overallLabels = [
                    'Causal Reasoning',
                    'Cognitive Reflection',
                    'Confidence Calibration',
                    'Metacognition',
                    'Reading Comprehension',
                    'Working Memory'
                ];
                var overallData = [
                    @((Model.Statistics.CausalReasoningWeightedAverage * 100).ToString("F0")),
                    @((Model.Statistics.CognitiveReflectionWeightedAverage * 100).ToString("F0")),
                    @((Model.Statistics.ConfidenceCalibrationWeightedAverage * 100).ToString("F0")),
                    @((Model.Statistics.MetacognitionWeightedAverage * 100).ToString("F0")),
                    @((Model.Statistics.ReadingComprehensionWeightedAverage * 100).ToString("F0")),
                    @((Model.Statistics.ShortTermMemoryWeightedAverage * 100).ToString("F0"))
                ];

                new Chart(document.getElementById('overallRadar'), {
                    type: 'polarArea',
                    data: {
                        labels: overallLabels,
                        datasets: [{
                            label: 'Weighted Average %',
                            data: overallData,
                            backgroundColor: [
                                'rgba(100, 160, 255, 0.6)',
                                'rgba(255, 160, 100, 0.6)',
                                'rgba(100, 220, 160, 0.6)',
                                'rgba(220, 100, 180, 0.6)',
                                'rgba(255, 220, 80, 0.6)',
                                'rgba(140, 100, 255, 0.6)'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: { r: { beginAtZero: true, max: 100, ticks: { stepSize: 20 } } },
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
                </text>
            }
        });
    </script>
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <h1 class="mb-1">@L["LessonComplete"]</h1>
            <p class="text-muted mb-4">@L["SessionSummaryIntro"]</p>

            <!-- ?? This session ??????????????????????????????????????? -->
            <div class="card mb-4">
                <div class="card-header fw-semibold">@L["ThisSession"]</div>
                <div class="card-body">
                    @if (Model.SessionResults.Count == 0)
                    {
                        <p class="text-muted">@L["NoResults"]</p>
                    }
                    else
                    {
                        <div class="row g-3 mb-3">
                            @foreach (var r in Model.SessionResults)
                            {
                                var badgeClass = r.ScorePercent >= 50 ? "bg-success" : "bg-danger";
                                <div class="col-sm-6 col-md-4">
                                    <div class="border rounded p-2 text-center">
                                        <div class="small text-muted">@r.Category</div>
                                        <span class="badge @badgeClass fs-6 mt-1">@r.Correct / @r.Attempted</span>
                                    </div>
                                </div>
                            }
                        </div>
                        <canvas id="sessionChart" height="250"></canvas>
                    }
                </div>
            </div>

            <!-- ?? Per-question breakdown ????????????????????????????? -->
            @if (Model.QuestionSummaryItems.Count > 0)
            {
                <div class="card mb-4">
                    <div class="card-header fw-semibold">@L["QuestionBreakdown"]</div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@L["QuestionColumn"]</th>
                                        <th class="text-center" style="width:120px">@L["CategoryColumn"]</th>
                                        <th class="text-center" style="width:90px">@L["YourAnswerColumn"]</th>
                                        <th class="text-center" style="width:130px">@L["AllUsersColumn"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.QuestionSummaryItems)
                                    {
                                        <tr>
                                            <td class="small">@item.QuestionText</td>
                                            <td class="text-center small">@item.Category</td>
                                            <td class="text-center">
                                                @if (item.UserCorrect)
                                                {
                                                    <span class="badge bg-success">@L["CorrectBadge"]</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">@L["IncorrectBadge"]</span>
                                                }
                                            </td>
                                            <td class="text-center small">
                                                @if (item.GlobalSuccessPercent.HasValue)
                                                {
                                                    <span>@item.GlobalSuccessPercent%</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Ś</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- ?? Overall statistics (only after 2+ lessons) ???????? -->
            @if (Model.Statistics != null && Model.LessonsCompleted >= 2)
            {
                <div class="card mb-4">
                    <div class="card-header fw-semibold">@L["OverallProgress"]</div>
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <span class="display-6 fw-bold">@((Model.Statistics.OverallWeightedAverage * 100).ToString("F0"))%</span>
                            <div class="text-muted small">@L["OverallWeightedAverage"]</div>
                        </div>

                        <canvas id="overallRadar" height="250" class="mb-4"></canvas>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@L["CategoryHeader"]</th>
                                        <th class="text-center">@L["AttemptsHeader"]</th>
                                        <th class="text-center">@L["PassedHeader"]</th>
                                        <th class="text-center">@L["WeightedAvgHeader"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>@L["CausalReasoning"]</td>
                                        <td class="text-center">@Model.Statistics.CausalReasoningAttempts</td>
                                        <td class="text-center">@Model.Statistics.CausalReasoningPassed</td>
                                        <td class="text-center">@((Model.Statistics.CausalReasoningWeightedAverage * 100).ToString("F0"))%</td>
                                    </tr>
                                    <tr>
                                        <td>@L["CognitiveReflection"]</td>
                                        <td class="text-center">@Model.Statistics.CognitiveReflectionAttempts</td>
                                        <td class="text-center">@Model.Statistics.CognitiveReflectionPassed</td>
                                        <td class="text-center">@((Model.Statistics.CognitiveReflectionWeightedAverage * 100).ToString("F0"))%</td>
                                    </tr>
                                    <tr>
                                        <td>@L["ConfidenceCalibration"]</td>
                                        <td class="text-center">@Model.Statistics.ConfidenceCalibrationAttempts</td>
                                        <td class="text-center">@Model.Statistics.ConfidenceCalibrationPassed</td>
                                        <td class="text-center">@((Model.Statistics.ConfidenceCalibrationWeightedAverage * 100).ToString("F0"))%</td>
                                    </tr>
                                    <tr>
                                        <td>@L["Metacognition"]</td>
                                        <td class="text-center">@Model.Statistics.MetacognitionAttempts</td>
                                        <td class="text-center">@Model.Statistics.MetacognitionPassed</td>
                                        <td class="text-center">@((Model.Statistics.MetacognitionWeightedAverage * 100).ToString("F0"))%</td>
                                    </tr>
                                    <tr>
                                        <td>@L["ReadingComprehension"]</td>
                                        <td class="text-center">@Model.Statistics.ReadingComprehensionAttempts</td>
                                        <td class="text-center">@Model.Statistics.ReadingComprehensionPassed</td>
                                        <td class="text-center">@((Model.Statistics.ReadingComprehensionWeightedAverage * 100).ToString("F0"))%</td>
                                    </tr>
                                    <tr>
                                        <td>@L["ShortTermMemory"]</td>
                                        <td class="text-center">@Model.Statistics.ShortTermMemoryAttempts</td>
                                        <td class="text-center">@Model.Statistics.ShortTermMemoryPassed</td>
                                        <td class="text-center">@((Model.Statistics.ShortTermMemoryWeightedAverage * 100).ToString("F0"))%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <div class="text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">@L["BackToHome"]</a>
            </div>
        </div>
    </div>
</div>

