@inject IStringLocalizer<HomeShortTermMemoryResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-4">@L["PageTitle"]</h1>

            <div class="text-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 200"
                     style="max-width:100%; height:auto; border:1px solid var(--border-color); border-radius:0.5rem; background:var(--bg-secondary); padding:1rem;"
                     aria-label="Diagram showing short-term memory as a buffer between incoming information and long-term memory, with an active maintenance loop"
                     role="img">
                    <defs>
                        <marker id="stm-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-muted)" />
                        </marker>
                        <marker id="stm-arr-accent" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-accent)" />
                        </marker>
                    </defs>

                    <!-- Incoming information node -->
                    <ellipse cx="68" cy="100" rx="58" ry="26"
                             fill="none" stroke="var(--border-accent)" stroke-width="1.5" />
                    <text x="68" y="96" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Incoming</text>
                    <text x="68" y="110" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Information</text>

                    <!-- Arrow: Incoming -> STM -->
                    <line x1="128" y1="100" x2="178" y2="100"
                          stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#stm-arr)" />

                    <!-- Short-Term Memory node -->
                    <rect x="180" y="72" width="120" height="56" rx="8"
                          fill="none" stroke="var(--text-accent)" stroke-width="2" />
                    <text x="240" y="97" text-anchor="middle" font-size="12"
                          font-family="Courier New, monospace" fill="var(--text-accent)">Short-Term</text>
                    <text x="240" y="113" text-anchor="middle" font-size="12"
                          font-family="Courier New, monospace" fill="var(--text-accent)">Memory</text>

                    <!-- Rehearsal / maintenance loop -->
                    <path d="M 220 72 Q 240 32 260 72" fill="none"
                          stroke="var(--text-accent)" stroke-width="1.5" stroke-dasharray="5,3"
                          marker-end="url(#stm-arr-accent)" />
                    <text x="240" y="28" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-accent)">rehearsal</text>

                    <!-- Fade / decay label -->
                    <text x="240" y="158" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-muted)">fades without rehearsal</text>
                    <line x1="240" y1="148" x2="240" y2="131"
                          stroke="var(--text-muted)" stroke-width="1" stroke-dasharray="3,3"
                          marker-end="url(#stm-arr)" />

                    <!-- Arrow: STM -> Long-Term -->
                    <line x1="302" y1="100" x2="352" y2="100"
                          stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#stm-arr)" />

                    <!-- Long-Term Memory node -->
                    <ellipse cx="414" cy="100" rx="58" ry="26"
                             fill="none" stroke="var(--border-accent)" stroke-width="1.5" />
                    <text x="414" y="96" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Long-Term</text>
                    <text x="414" y="110" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Memory</text>
                </svg>
            </div>

            <section class="mb-5">
                <p>@Html.Raw(L["Intro1"].Value)</p>
                <p>@Html.Raw(L["Intro2"].Value)</p>
            </section>

            <section class="mb-5">
                <h2 class="h4 mb-3">@L["HowPracticeHelps"]</h2>
                <p>@Html.Raw(L["Practice1"].Value)</p>
                <p>@Html.Raw(L["Practice2"].Value)</p>
                <p>@Html.Raw(L["Practice3"].Value)</p>
            </section>

            <hr class="my-5" />

            <section class="mb-4">
                <h2 class="h5 mb-3">@L["References"]</h2>
                <ul class="list-unstyled ps-2" style="font-size:0.9rem; color:var(--text-muted);">
                    <li class="mb-2">@Html.Raw(L["Ref_Baddeley"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Cowan"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Klingberg"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Shipstead"].Value)</li>
                </ul>
            </section>

        </div>
    </div>
</div>
