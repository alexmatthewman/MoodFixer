@inject IStringLocalizer<HomeAboutResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-5">@ViewData["Title"]</h1>

            <section class="mb-5">
                <h2 class="h4 mb-3">@L["WhoAreWe"]</h2>
                <p>@L["WhoAreWeDesc1"]</p>
                <p>@L["WhoAreWeDesc2"]</p>
            </section>

            <section class="mb-5">
                <h2 class="h4 mb-3">@L["AboutExercises"]</h2>
                <p>@L["AboutExercisesDesc1"]</p>
                <p>@L["AboutExercisesDesc2"]</p>
                <p>@L["ExercisesTarget"]</p>
                <ul class="list-unstyled ps-3">
                    <li class="mb-2"><strong>@L["CognitiveReflection"]</strong> &mdash; @L["CognitiveReflectionDesc"]</li>
                    <li class="mb-2"><strong>@L["ReadingComprehension"]</strong> &mdash; @L["ReadingComprehensionDesc"]</li>
                    <li class="mb-2"><strong>@L["CausalReasoning"]</strong> &mdash; @L["CausalReasoningDesc"]</li>
                    <li class="mb-2"><strong>@L["Metacognition"]</strong> &mdash; @L["MetacognitionDesc"]</li>
                    <li class="mb-2"><strong>@L["ShortTermMemory"]</strong> &mdash; @L["ShortTermMemoryDesc"]</li>
                    <li class="mb-2"><strong>@L["ConfidenceCalibration"]</strong> &mdash; @L["ConfidenceCalibrationDesc"]</li>
                </ul>
            </section>

        </div>
    </div>
</div>
