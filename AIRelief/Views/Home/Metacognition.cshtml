@inject IStringLocalizer<HomeMetacognitionResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-4">@L["PageTitle"]</h1>

            <div class="text-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 220"
                     style="max-width:100%; height:auto; border:1px solid var(--border-color); border-radius:0.5rem; background:var(--bg-secondary); padding:1rem;"
                     aria-label="Diagram showing a layered model of metacognition: an outer ring labelled Metacognition surrounds an inner ring labelled Cognition, which in turn surrounds a central node labelled Thinking"
                     role="img">
                    <defs>
                        <marker id="meta-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-muted)" />
                        </marker>
                    </defs>

                    <!-- Outer ring: Metacognition -->
                    <ellipse cx="240" cy="110" rx="210" ry="95"
                             fill="none" stroke="var(--border-accent)" stroke-width="1.5" stroke-dasharray="6,4" />
                    <text x="240" y="22" text-anchor="middle" font-size="13"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Metacognition</text>
                    <text x="240" y="37" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-muted)">(thinking about thinking)</text>

                    <!-- Middle ring: Cognition -->
                    <ellipse cx="240" cy="115" rx="140" ry="66"
                             fill="none" stroke="var(--border-accent)" stroke-width="1.5" />
                    <text x="240" y="59" text-anchor="middle" font-size="13"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Cognition</text>

                    <!-- Central node: Thinking -->
                    <ellipse cx="240" cy="120" rx="68" ry="30"
                             fill="none" stroke="var(--text-accent)" stroke-width="1.5" />
                    <text x="240" y="125" text-anchor="middle" font-size="13"
                          font-family="Courier New, monospace" fill="var(--text-accent)">Thinking</text>

                    <!-- Self-monitoring arrow (loops back from Metacognition toward Cognition) -->
                    <path d="M 66 90 Q 30 110 66 140" fill="none" stroke="var(--text-muted)"
                          stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#meta-arr)" />
                    <text x="12" y="118" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-muted)" transform="rotate(-90,22,115)">monitor</text>

                    <!-- Self-regulation arrow (right side) -->
                    <path d="M 414 140 Q 450 115 414 90" fill="none" stroke="var(--text-muted)"
                          stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#meta-arr)" />
                    <text x="462" y="118" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-muted)" transform="rotate(90,458,115)">regulate</text>
                </svg>
            </div>

            <section class="mb-5">
                <p>@Html.Raw(L["Intro1"].Value)</p>
                <p>@Html.Raw(L["Intro2"].Value)</p>
            </section>

            <hr class="my-5" />

            <section class="mb-4">
                <h2 class="h5 mb-3">@L["References"]</h2>
                <ul class="list-unstyled ps-2" style="font-size:0.9rem; color:var(--text-muted);">
                    <li class="mb-2">@Html.Raw(L["Ref_Flavell"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Nelson"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Kuhn"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Dunlosky"].Value)</li>
                </ul>
            </section>

        </div>
    </div>
</div>
