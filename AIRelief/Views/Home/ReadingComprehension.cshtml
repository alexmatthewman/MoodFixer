@inject IStringLocalizer<HomeReadingComprehensionResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-4">@L["PageTitle"]</h1>

            <div class="text-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 200"
                     style="max-width:100%; height:auto; border:1px solid var(--border-color); border-radius:0.5rem; background:var(--bg-secondary); padding:1rem;"
                     aria-label="Diagram showing the layers of reading comprehension: words on the page lead to literal meaning, which leads to inference, which leads to critical evaluation"
                     role="img">
                    <defs>
                        <marker id="rc-arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-muted)" />
                        </marker>
                    </defs>

                    <!-- Stage 1: Words on the page -->
                    <rect x="16" y="70" width="95" height="60" rx="6"
                          fill="none" stroke="var(--border-color)" stroke-width="1.5" />
                    <text x="63" y="96" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Words</text>
                    <text x="63" y="112" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-muted)">on the page</text>

                    <!-- Arrow 1 -->
                    <line x1="113" y1="100" x2="141" y2="100"
                          stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rc-arr)" />

                    <!-- Stage 2: Literal meaning -->
                    <rect x="143" y="70" width="95" height="60" rx="6"
                          fill="none" stroke="var(--border-color)" stroke-width="1.5" />
                    <text x="190" y="96" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Literal</text>
                    <text x="190" y="112" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-muted)">meaning</text>

                    <!-- Arrow 2 -->
                    <line x1="240" y1="100" x2="268" y2="100"
                          stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rc-arr)" />

                    <!-- Stage 3: Inference -->
                    <rect x="270" y="70" width="95" height="60" rx="6"
                          fill="none" stroke="var(--border-accent)" stroke-width="1.5" />
                    <text x="317" y="96" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-secondary)">Inference</text>
                    <text x="317" y="112" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-muted)">&amp; implication</text>

                    <!-- Arrow 3 -->
                    <line x1="367" y1="100" x2="395" y2="100"
                          stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#rc-arr)" />

                    <!-- Stage 4: Critical evaluation -->
                    <rect x="397" y="70" width="67" height="60" rx="6"
                          fill="none" stroke="var(--text-accent)" stroke-width="1.5" />
                    <text x="430" y="96" text-anchor="middle" font-size="11"
                          font-family="Courier New, monospace" fill="var(--text-accent)">Critical</text>
                    <text x="430" y="112" text-anchor="middle" font-size="10"
                          font-family="Courier New, monospace" fill="var(--text-accent)">evaluation</text>

                    <!-- Label row above -->
                    <text x="63"  y="58" text-anchor="middle" font-size="9"
                          font-family="Courier New, monospace" fill="var(--text-muted)">decode</text>
                    <text x="190" y="58" text-anchor="middle" font-size="9"
                          font-family="Courier New, monospace" fill="var(--text-muted)">understand</text>
                    <text x="317" y="58" text-anchor="middle" font-size="9"
                          font-family="Courier New, monospace" fill="var(--text-muted)">interpret</text>
                    <text x="430" y="58" text-anchor="middle" font-size="9"
                          font-family="Courier New, monospace" fill="var(--text-accent)">evaluate</text>
                </svg>
            </div>

            <section class="mb-5">
                <p>@Html.Raw(L["Intro1"].Value)</p>
                <p>@Html.Raw(L["Intro2"].Value)</p>
                <p>@Html.Raw(L["Intro3"].Value)</p>
            </section>

            <hr class="my-5" />

            <section class="mb-4">
                <h2 class="h5 mb-3">@L["References"]</h2>
                <ul class="list-unstyled ps-2" style="font-size:0.9rem; color:var(--text-muted);">
                    <li class="mb-2">@Html.Raw(L["Ref_Kintsch"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_McNamara"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_NRP"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Perfetti"].Value)</li>
                </ul>
            </section>

        </div>
    </div>
</div>
