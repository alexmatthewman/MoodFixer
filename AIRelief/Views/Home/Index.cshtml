            </div>

            <div class="col-md-3 mb-4">
                <div class="process-step">
                    <div class="step-number">3</div>
                    <div class="step-icon">
                        <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=150&h=150&fit=crop&q=80"
                             alt="Practice and application"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback">
                            <i class="fas fa-code fa-3x"></i>
                        </div>
                    </div>
                    <h4>@L["Step3_Title"]</h4>
                    <p>@L["Step3_Desc"]</p>
