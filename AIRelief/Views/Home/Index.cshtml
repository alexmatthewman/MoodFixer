                            <i class="fas fa-chart-bar fa-3x"></i>
                        </div>
                    </div>
                    <h4>@L["Step4_Title"]</h4>
                    <p>@L["Step4_Desc"]</p>
                </div>
            </div>
        </div>

        <!-- Process CTA -->
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto text-center">
                <div class="process-cta">
                    <h3>@L["StartWithStep1"]</h3>
                    <p>@L["StartWithStep1Desc"]</p>
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">
                        @L["BeginAssessment"] <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section id="start-assessment" class="cta-section fade-in-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h2 class="cta-title">@T.Get("ReadyToReclaim")</h2>
                <p class="cta-subtitle">
                    @T.Get("JoinDevelopers")
                </p>

                <div class="cta-buttons">
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">
                        @L["StartFreeTrialAssessment"]
                    </a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-controller="Questions" asp-action="Index" class="btn btn-outline-primary btn-lg">
                            @L["AccessFullProgram"]
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary btn-lg">
                            @L["SignUpForFullAccess"]
                        </a>
                    }
                </div>

                <div class="cta-guarantee">
                    <i class="fas fa-shield-alt"></i>
                    <span>@L["TrialGuarantee"]</span>
                </div>
            </div>
        </div>
    </div>
</section>

