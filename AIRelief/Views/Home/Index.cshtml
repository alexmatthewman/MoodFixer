@inject IStringLocalizer<HomeIndexResource> L
@inject AIRelief.Services.CompositeTranslationService T
@{
    ViewData["Title"] = L["PageTitle"].Value;

}

@section Scripts {
    <script type="text/javascript">
        // Image fallback handling
        function handleImageError(img) {
            img.style.display = 'none';
            const fallback = img.nextElementSibling;
            if (fallback && fallback.classList.contains('image-fallback')) {
                fallback.style.display = 'flex';
            }
        }

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Intersection Observer for animations
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate-in');
                }
            });
        }, observerOptions);

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.fade-in-section').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6">
                <h1 class="hero-title">
                    @T.Get("HeroTitle_Prefix") <span class="text-accent">@T.Get("HeroTitle_Accent")</span>
                </h1>
                <p class="hero-subtitle">
                    @T.Get("HeroSubtitle")
                </p>
                <div class="hero-stats">
                    <div class="stat-item">
                        <span class="stat-number">@L["Stat_SkillAtrophy_Number"]</span>
                        <span class="stat-label">@L["Stat_SkillAtrophy_Label"]</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">@L["Stat_Confidence_Number"]</span>
                        <span class="stat-label">@L["Stat_Confidence_Label"]</span>
                    </div>
                </div>
                <div class="hero-buttons">
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">@T.Get("StartFreeTrial")</a>
                    <a href="#learn-more" class="btn btn-outline-primary btn-lg">@L["LearnMore"]</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image">
                    <img src="https://images.unsplash.com/photo-1677442136019-21780ecad995?w=600&h=400&fit=crop&q=80"
                         alt="AI and Human Brain Balance"
                         class="img-fluid hero-main-image"
                         onerror="handleImageError(this)" />
                    <div class="image-fallback">
                        <i class="fas fa-brain fa-8x"></i>
                        <p>@L["ImageFallback_Brain"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="scroll-indicator">
        <a href="#problem" class="scroll-arrow">
            <i class="fas fa-chevron-down"></i>
        </a>
    </div>
</section>

<!-- Problem Section -->
<section id="problem" class="problem-section fade-in-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h2 class="section-title">@L["HiddenCostTitle"]</h2>
                <p class="section-subtitle">
                    @L["HiddenCostSubtitle"]
                </p>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-md-4 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=300&h=200&fit=crop&q=80"
                             alt="Brain with gears"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback">
                            <i class="fas fa-brain fa-3x"></i>
                        </div>
                    </div>
                    <h3>@L["CognitiveOffloading"]</h3>
                    <p>@L["CognitiveOffloadingDesc"]</p>
                    <a href="https://www.nature.com/articles/s41586-023-05886-6" target="_blank" class="problem-link">
                        @L["ReadResearch"] <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1559757175-0eb30cd8c063?w=300&h=200&fit=crop&q=80"
                             alt="Puzzle pieces"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback">
                            <i class="fas fa-puzzle-piece fa-3x"></i>
                        </div>
                    </div>
                    <h3>@L["ProblemSolvingAtrophy"]</h3>
                    <p>@L["ProblemSolvingAtrophyDesc"]</p>
                    <a href="https://arxiv.org/abs/2308.07124" target="_blank" class="problem-link">
                        @L["ViewStudy"] <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=300&h=200&fit=crop&q=80"
                             alt="Lightbulb and innovation"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback">
                            <i class="fas fa-lightbulb fa-3x"></i>
                        </div>
                    </div>
                    <h3>@L["CreativeThinkingDecline"]</h3>
                    <p>@L["CreativeThinkingDeclineDesc"]</p>
                    <a href="https://hbr.org/2024/01/how-ai-is-changing-work" target="_blank" class="problem-link">
                        @L["ReadArticle"] <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Call to action after problem presentation -->
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto text-center">
                <div class="problem-cta">
                    <h3>@L["TestYourSkills"]</h3>
                    <p>@L["TestYourSkillsDesc"]</p>
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">
                        @L["TakeFreeAssessment"] <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Solution Section -->
<section id="learn-more" class="solution-section fade-in-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 order-lg-2">
                <div class="solution-image">
                    <img src="https://images.unsplash.com/photo-1581291518633-83b4ebd1d83e?w=500&h=400&fit=crop&q=80"
                         alt="Critical thinking process flowchart"
                         class="img-fluid"
                         onerror="handleImageError(this)" />
                    <div class="image-fallback">
                        <i class="fas fa-project-diagram fa-6x"></i>
                        <p>@L["ImageFallback_CriticalThinking"]</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 order-lg-1">
                <h2 class="section-title">@T.Get("CognitiveFitnessProgramTitle")</h2>
                <p class="section-subtitle">
                    @T.Get("CognitiveFitnessProgramSubtitle")
                </p>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-target"></i>
                        </div>
                        <div class="feature-content">
                            <h4>@L["TargetedSkillAssessment"]</h4>
                            <p>@L["TargetedSkillAssessmentDesc"]</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-dumbbell"></i>
                        </div>
                        <div class="feature-content">
                            <h4>@L["ProgressiveTraining"]</h4>
                            <p>@L["ProgressiveTrainingDesc"]</p>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="feature-content">
                            <h4>@L["MeasurableProgress"]</h4>
                            <p>@L["MeasurableProgressDesc"]</p>
                        </div>
                    </div>
                </div>

                <!-- Trial CTA in solution section -->
                <div class="solution-cta mt-4">
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-outline-primary">
                        @L["TrySampleQuestions"] <i class="fas fa-play"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

