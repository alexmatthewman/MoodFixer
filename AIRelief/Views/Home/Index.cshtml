                             alt="Training and education"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback">
                            <i class="fas fa-graduation-cap fa-3x"></i>
                        </div>
                    </div>
                    <h4>@L["Step2_Title"]</h4>
                    <p>@L["Step2_Desc"]</p>
