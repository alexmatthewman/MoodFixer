@inject IStringLocalizer<HomeCognitiveReflectionResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-4">@L["PageTitle"]</h1>

            <div class="text-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 210"
                     style="max-width:100%; height:auto; border:1px solid var(--border-color); border-radius:0.5rem; background:var(--bg-secondary); padding:1rem;"
                     aria-label="Diagram contrasting fast intuitive thinking on the left with slow deliberate reflection on the right, connected by a pause symbol in the centre"
                     role="img">

                    <!-- System 1: fast / intuitive -->
                    <rect x="20" y="60" width="130" height="90" rx="8" fill="none" stroke="var(--border-color)" stroke-width="1.5"/>
                    <text x="85" y="90" text-anchor="middle" font-size="12" font-family="Courier New, monospace" fill="var(--text-muted)">System 1</text>
                    <text x="85" y="108" text-anchor="middle" font-size="11" font-family="Courier New, monospace" fill="var(--text-secondary)">Fast &amp; Intuitive</text>
                    <text x="85" y="126" text-anchor="middle" font-size="10" font-family="Courier New, monospace" fill="var(--text-muted)">gut response</text>

                    <!-- Arrow right from System 1 -->
                    <line x1="152" y1="105" x2="196" y2="105" stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#arr)"/>

                    <!-- Pause / reflect node -->
                    <ellipse cx="240" cy="105" rx="38" ry="28" fill="none" stroke="var(--border-accent)" stroke-width="1.5"/>
                    <text x="240" y="100" text-anchor="middle" font-size="18" font-family="Courier New, monospace" fill="var(--text-accent)">&#9616;&#9616;</text>
                    <text x="240" y="118" text-anchor="middle" font-size="10" font-family="Courier New, monospace" fill="var(--text-accent)">pause</text>

                    <!-- Arrow right from pause -->
                    <line x1="280" y1="105" x2="324" y2="105" stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#arr)"/>

                    <!-- System 2: slow / deliberate -->
                    <rect x="330" y="60" width="130" height="90" rx="8" fill="none" stroke="var(--border-accent)" stroke-width="1.5"/>
                    <text x="395" y="90" text-anchor="middle" font-size="12" font-family="Courier New, monospace" fill="var(--text-muted)">System 2</text>
                    <text x="395" y="108" text-anchor="middle" font-size="11" font-family="Courier New, monospace" fill="var(--text-secondary)">Slow &amp; Deliberate</text>
                    <text x="395" y="126" text-anchor="middle" font-size="10" font-family="Courier New, monospace" fill="var(--text-muted)">careful analysis</text>

                    <!-- Labels above boxes -->
                    <text x="85"  y="48" text-anchor="middle" font-size="10" font-family="Courier New, monospace" fill="var(--text-muted)">first impulse</text>
                    <text x="395" y="48" text-anchor="middle" font-size="10" font-family="Courier New, monospace" fill="var(--text-accent)">considered judgment</text>

                    <defs>
                        <marker id="arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-muted)"/>
                        </marker>
                    </defs>
                </svg>
            </div>

            <section class="mb-5">
                <p>@Html.Raw(L["Intro1"].Value)</p>
                <p>@Html.Raw(L["Intro2"].Value)</p>
                <p>@Html.Raw(L["Intro3"].Value)</p>
                <p>@Html.Raw(L["Intro4"].Value)</p>
            </section>

            <hr class="my-5" />

            <section class="mb-4">
                <h2 class="h5 mb-3">@L["References"]</h2>
                <ul class="list-unstyled ps-2" style="font-size:0.9rem; color:var(--text-muted);">
                    <li class="mb-2">@Html.Raw(L["Ref_Frederick"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Toplak"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Kahneman"].Value)</li>
                </ul>
            </section>

        </div>
    </div>
</div>