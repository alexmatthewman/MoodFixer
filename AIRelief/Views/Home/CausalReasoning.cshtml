@inject IStringLocalizer<HomeCausalReasoningResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-4">@L["PageTitle"]</h1>

            <div class="text-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 200"
                     style="max-width:100%; height:auto; border:1px solid var(--border-color); border-radius:0.5rem; background:var(--bg-secondary); padding:1rem;"
                     aria-label="Diagram showing three causal paths from a confounding variable to both the cause and the effect, illustrating the difference between association and causation"
                     role="img">
                    <!-- Confounder node -->
                    <ellipse cx="240" cy="40" rx="70" ry="24" fill="none" stroke="var(--border-accent)" stroke-width="1.5"/>
                    <text x="240" y="45" text-anchor="middle" font-size="13" font-family="Courier New, monospace" fill="var(--text-secondary)">Confounder</text>

                    <!-- Confounder ? Cause arrow -->
                    <line x1="178" y1="56" x2="108" y2="116" stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#arr)"/>
                    <!-- Confounder ? Effect arrow -->
                    <line x1="302" y1="56" x2="372" y2="116" stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#arr)"/>

                    <!-- Cause node -->
                    <ellipse cx="90" cy="138" rx="60" ry="24" fill="none" stroke="var(--border-accent)" stroke-width="1.5"/>
                    <text x="90" y="143" text-anchor="middle" font-size="13" font-family="Courier New, monospace" fill="var(--text-secondary)">Cause?</text>

                    <!-- Effect node -->
                    <ellipse cx="390" cy="138" rx="60" ry="24" fill="none" stroke="var(--border-accent)" stroke-width="1.5"/>
                    <text x="390" y="143" text-anchor="middle" font-size="13" font-family="Courier New, monospace" fill="var(--text-secondary)">Effect</text>

                    <!-- Spurious association dashed line -->
                    <line x1="152" y1="138" x2="328" y2="138" stroke="var(--text-accent)" stroke-width="1.5" stroke-dasharray="6,4" marker-end="url(#arrAccent)"/>
                    <text x="240" y="130" text-anchor="middle" font-size="11" font-family="Courier New, monospace" fill="var(--text-accent)">spurious association?</text>

                    <defs>
                        <marker id="arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-muted)"/>
                        </marker>
                        <marker id="arrAccent" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                            <path d="M0,0 L0,6 L8,3 z" fill="var(--text-accent)"/>
                        </marker>
                    </defs>
                </svg>
            </div>

            <section class="mb-5">
                <p>@Html.Raw(L["Intro1"].Value)</p>
                <p>@Html.Raw(L["Intro2"].Value)</p>
            </section>

            <section class="mb-5">
                <h2 class="h4 mb-3">@L["HowPracticeHelps"]</h2>
                <p>@Html.Raw(L["Practice1"].Value)</p>
            </section>

            <hr class="my-5" />

            <section class="mb-4">
                <h2 class="h5 mb-3">@L["References"]</h2>
                <ul class="list-unstyled ps-2" style="font-size:0.9rem; color:var(--text-muted);">
                    <li class="mb-2">@Html.Raw(L["Ref_Hernan"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Pearl"].Value)</li>
                    <li class="mb-2">@Html.Raw(L["Ref_Sloman"].Value)</li>
                </ul>
            </section>

        </div>
    </div>
</div>
