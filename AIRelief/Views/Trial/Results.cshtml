@model TrialResultViewModel
@inject IStringLocalizer<TrialResultsResource> L

@{
    ViewData["Title"] = L["PageTitle"].Value;
}

<section class="results-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="results-card">
                    <div class="score-display">
                        <div class="score-circle">
                            <span class="score-percentage">@Model.Percentage%</span>
                            <span class="score-fraction">@Model.Score/@Model.TotalQuestions</span>
                        </div>
                    </div>

                    <h2 class="results-title">@Model.Message</h2>

                    @if (Model.ShowTrainingSuggestion)
                    {
                        <div class="training-suggestion">
                            <h3>@L["StrengthenYourSkills"]</h3>
                            <p>@L["StrengthenDesc"]</p>

                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <a asp-controller="Questions" asp-action="Index" class="btn btn-primary btn-lg">
                                    @L["StartFullAssessment"]
                                </a>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">
                                    @L["SignUpForFullAccess"]
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="success-message">
                            <h3>@L["WellDone"]</h3>
                            <p>@L["WellDoneDesc"]</p>

                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <a asp-controller="Questions" asp-action="Index" class="btn btn-primary btn-lg">
                                    @L["AccessFullProgram"]
                                </a>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">
                                    @L["JoinUs"]
                                </a>
                            }
                        </div>
                    }

                    <div class="trial-actions">
                        <a asp-action="Index" class="btn btn-outline-primary">@L["TakeTrialAgain"]</a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-link">@L["ReturnHome"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>