@inject AIRelief.Services.CompositeTranslationService T
@inject IStringLocalizer<HomeIndexResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
}

@section Scripts {
    <script type="text/javascript">
        function handleImageError(img) {
            img.style.display = 'none';
            const fallback = img.nextElementSibling;
            if (fallback && fallback.classList.contains('image-fallback')) {
                fallback.style.display = 'flex';
            }
        }

        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) { entry.target.classList.add('animate-in'); }
            });
        }, observerOptions);

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.fade-in-section').forEach(el => { observer.observe(el); });
        });
    </script>
}

<!-- Hero Section -->
<section class="hero-section">
<div class="container">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h1 class="hero-title">
                @T.Get("HeroTitle_Prefix") <span class="text-accent">@T.Get("HeroTitle_Accent")</span>
            </h1>
            <p class="hero-subtitle">@T.Get("HeroSubtitle")</p>
                <div class="hero-stats">
                    <div class="stat-item">
                        <span class="stat-number">@L["Stat_SkillAtrophy_Number"]</span>
                        <span class="stat-label">@L["Stat_SkillAtrophy_Label"]</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">@L["Stat_Confidence_Number"]</span>
                        <span class="stat-label">@L["Stat_Confidence_Label"]</span>
                    </div>
                </div>
                <div class="hero-buttons">
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">@T.Get("StartFreeTrial")</a>
                    <a asp-controller="Signup" asp-action="Index" class="btn btn-outline-primary btn-lg">@L["ViewPlansAndPricing"]</a>
                    <a href="#learn-more" class="btn btn-outline-secondary btn-lg">@L["LearnMore"]</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image">
                    <img src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=600&h=400&fit=crop&q=80"
                         alt="Neural network visualization"
                         class="img-fluid hero-main-image"
                         onerror="handleImageError(this)" />
                    <div class="image-fallback">
                        <i class="fas fa-brain fa-8x"></i>
                        <p>@L["ImageFallback_Brain"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="scroll-indicator">
        <a href="#problem" class="scroll-arrow"><i class="fas fa-chevron-down"></i></a>
    </div>
</section>

<!-- Problem Section -->
<section id="problem" class="problem-section fade-in-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h2 class="section-title">@L["HiddenCostTitle"]</h2>
                <p class="section-subtitle">@L["HiddenCostSubtitle"]</p>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-md-4 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1507413245164-6160d8298b31?w=300&h=200&fit=crop&q=80"
                             alt="Laboratory research"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback"><i class="fas fa-brain fa-3x"></i></div>
                    </div>
                    <h3>@L["CognitiveOffloading"]</h3>
                    <p>@L["CognitiveOffloadingDesc"]</p>
                    <a href="https://arxiv.org/pdf/2506.08872v1" target="_blank" class="problem-link">
                        @L["ReadResearch"] <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1582719471384-894fbb16e074?w=300&h=200&fit=crop&q=80"
                             alt="Brain scan MRI"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback"><i class="fas fa-puzzle-piece fa-3x"></i></div>
                    </div>
                    <h3>@L["ProblemSolvingAtrophy"]</h3>
                    <p>@L["ProblemSolvingAtrophyDesc"]</p>
                    <a href="https://www.anthropic.com/research/AI-assistance-coding-skills" target="_blank" class="problem-link">
                        @L["ViewStudy"] <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1532094349884-543bc11b234d?w=300&h=200&fit=crop&q=80"
                             alt="Data analysis screens"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback"><i class="fas fa-lightbulb fa-3x"></i></div>
                    </div>
                    <h3>@L["CreativeThinkingDecline"]</h3>
                    <p>@L["CreativeThinkingDeclineDesc"]</p>
                    <a href="https://hbr.org/2026/01/why-ai-boosts-creativity-for-some-employees-but-not-others" target="_blank" class="problem-link">
                        @L["ReadArticle"] <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Additional supporting studies row -->
        <div class="row mt-5">
            <div class="col-md-6 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=300&h=200&fit=crop&q=80"
                             alt="Developer productivity"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback"><i class="fas fa-chart-line fa-3x"></i></div>
                    </div>
                    <h3>Productivity Paradox in Experienced Developers</h3>
                    <p>A 2025 METR randomized controlled trial with experienced open-source developers found that using AI tools resulted in 19% longer task completion times on real issues in their own repositories. Developers incorrectly believed AI made them ~20-24% faster.</p>
                    <a href="https://metr.org/blog/2025-07-10-early-2025-ai-experienced-os-dev-study/" target="_blank" class="problem-link">
                        View METR Study <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="problem-card">
                    <div class="problem-image">
                        <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=300&h=200&fit=crop&q=80"
                             alt="Critical thinking survey"
                             onerror="handleImageError(this)" />
                        <div class="image-fallback"><i class="fas fa-book-reader fa-3x"></i></div>
                    </div>
                    <h3>Reduced Critical Thinking &amp; Engagement</h3>
                    <p>Studies, including Microsoft Research surveys and reviews on generative AI in knowledge work, show that frequent AI use correlates with reduced critical thinking, lower cognitive engagement, and increased cognitive offloading across tasks.</p>
                    <a href="https://www.microsoft.com/en-us/research/wp-content/uploads/2025/01/lee_2025_ai_critical_thinking_survey.pdf" target="_blank" class="problem-link">
                        Read Report <i class="fas fa-external-link-alt"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-lg-8 mx-auto text-center">
                <div class="problem-cta">
                    <h3>@L["TestYourSkills"]</h3>
                    <p>@L["TestYourSkillsDesc"]</p>
                    <div class="d-flex flex-wrap gap-3 justify-content-center">
                        <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">
                            @L["TakeFreeAssessment"] <i class="fas fa-arrow-right"></i>
                        </a>
                        <a asp-controller="Signup" asp-action="Index" class="btn btn-outline-primary btn-lg">
                            @L["SubscribeNow"] <i class="fas fa-bolt"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Solution Section -->
<section id="learn-more" class="solution-section fade-in-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 order-lg-2">
                <div class="solution-image">
                    <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=500&h=400&fit=crop&q=80"
                         alt="Strategic analysis"
                         class="img-fluid"
                         onerror="handleImageError(this)" />
                    <div class="image-fallback">
                        <i class="fas fa-project-diagram fa-6x"></i>
                        <p>@L["ImageFallback_CriticalThinking"]</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 order-lg-1">
                <h2 class="section-title">@T.Get("CognitiveFitnessProgramTitle")</h2>
                <p class="section-subtitle">@T.Get("CognitiveFitnessProgramSubtitle")</p>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-target"></i></div>
                        <div class="feature-content">
                            <h4>@L["TargetedSkillAssessment"]</h4>
                            <p>@L["TargetedSkillAssessmentDesc"]</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-dumbbell"></i></div>
                        <div class="feature-content">
                            <h4>@L["ProgressiveTraining"]</h4>
                            <p>@L["ProgressiveTrainingDesc"]</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-chart-line"></i></div>
                        <div class="feature-content">
                            <h4>@L["MeasurableProgress"]</h4>
                            <p>@L["MeasurableProgressDesc"]</p>
                        </div>
                    </div>
                </div>

                <div class="solution-cta mt-4">
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-outline-primary">
                        @L["TrySampleQuestions"] <i class="fas fa-play"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

