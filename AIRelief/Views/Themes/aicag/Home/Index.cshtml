            <div class="col-md-3 mb-4">
                <div class="process-step">
                    <div class="step-number">2</div>
                    <div class="step-icon">
                        <img src="https://images.unsplash.com/photo-1580894894513-541e068a3e2b?w=150&h=150&fit=crop&q=80"
                             alt="Brain training" onerror="handleImageError(this)" />
                        <div class="image-fallback"><i class="fas fa-graduation-cap fa-3x"></i></div>
                    </div>
                    <h4>@L["Step2_Title"]</h4>
                    <p>@L["Step2_Desc"]</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="process-step">
