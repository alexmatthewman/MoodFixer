                    <p>@L["StartWithStep1Desc"]</p>
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">
                        @L["BeginAssessment"] <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section id="start-assessment" class="cta-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h2 class="cta-title">@T.Get("ReadyToReclaim")</h2>
                <p class="cta-subtitle">@T.Get("JoinDevelopers")</p>
                <div class="cta-buttons">
                    <a asp-controller="Trial" asp-action="Index" class="btn btn-primary btn-lg">@L["StartFreeTrialAssessment"]</a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-controller="Questions" asp-action="Index" class="btn btn-outline-primary btn-lg">@L["AccessFullProgram"]</a>
                    }
                    else
                    {
                        <a asp-controller="Signup" asp-action="Index" class="btn btn-outline-primary btn-lg">@L["ViewPlansAndSignUp"]</a>
                    }
                </div>
                <div class="cta-guarantee">
                    <span>@L["TrialGuarantee"]</span>
                </div>
            </div>
        </div>
    </div>
</section>

