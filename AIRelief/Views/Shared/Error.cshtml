@inject IStringLocalizer<AIRelief.Controllers.HomeController> Localizer
@{
    ViewData["Title"] = Localizer["ErrorTitle"];
}

<div class="text-center mt-5">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> @Localizer["ErrorTitle"]</h1>
    <p class="lead mt-3">@Localizer["ErrorOccurred"]</p>
    <p>@Localizer["ErrorAdminNotified"]</p>
    <a href="/" class="btn btn-primary mt-3">@Localizer["ErrorBackToHome"]</a>
</div>
