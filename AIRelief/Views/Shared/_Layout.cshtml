<!DOCTYPE html>
@using AIRelief.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject AIReliefContext LayoutContext
@inject UserManager<IdentityUser> LayoutUserManager
@inject IStringLocalizer<SharedLayoutResource> L
@inject AIRelief.Services.CompositeTranslationService T
@{
    var layoutIdentityUser = await LayoutUserManager.GetUserAsync(User);
    var layoutAppUser = layoutIdentityUser == null ? null : await LayoutContext.Users
        .Include(u => u.Group)
        .FirstOrDefaultAsync(u => u.Email == layoutIdentityUser.Email);

    var tenant = Context.Items["Tenant"] as TenantConfig;
    var themeFolder = tenant?.ThemeFolder ?? "relief";

    // If the signed-in user's TenantCode doesn't match this site, treat them as anonymous
    // in the nav (the login pages will also block them from completing a fresh sign-in).
    var layoutTenantMismatch = layoutAppUser != null
        && layoutAppUser.AuthLevel != AuthLevel.SystemAdmin
        && !string.Equals(layoutAppUser.TenantCode, tenant?.MarketCode ?? "relief", StringComparison.OrdinalIgnoreCase);

    if (layoutTenantMismatch) layoutAppUser = null;

    var layoutIsSystemAdmin = layoutAppUser?.AuthLevel == AuthLevel.SystemAdmin;
    var layoutGroup = (layoutAppUser?.AuthLevel == AuthLevel.GroupAdmin || layoutAppUser?.AuthLevel == AuthLevel.User)
        ? layoutAppUser.Group
        : null;
    var layoutPrimary   = layoutGroup?.PrimaryThemeColor;
    var layoutSecondary = layoutGroup?.SecondaryThemeColor;
    var layoutLogoUrl   = layoutGroup?.GroupImageUrl;
    bool hasGroupTheme  = layoutGroup != null && (!string.IsNullOrWhiteSpace(layoutPrimary) || !string.IsNullOrWhiteSpace(layoutSecondary));

    // Read theme preference from cookie so the server-rendered HTML already
    // carries the correct data-theme attribute (avoids flash on cached pages).
    var savedTheme = Context.Request.Cookies["theme"];
    var htmlTheme  = string.Equals(savedTheme, "light", StringComparison.OrdinalIgnoreCase) ? "light" : "dark";
    var darkModeLabel = L["DarkMode"].Value;
    var lightModeLabel = L["LightMode"].Value;
}
<html lang="@(tenant?.DefaultLanguage ?? "en")" data-theme="@htmlTheme" data-bs-theme="@htmlTheme">
<head>
    <script>(function(){var d=document.documentElement;var n=function(v){return v==='light'||v==='dark'?v:null;};var m=document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);var c=n(m?decodeURIComponent(m[1]):null);var s=null;try{s=n(window.localStorage.getItem('theme'));}catch(e){}var t=s||c||'@htmlTheme';d.setAttribute('data-theme',t);d.setAttribute('data-bs-theme',t);d.style.colorScheme=t;})();</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(tenant?.SiteName ?? "AI Relief") - @T.Get("SiteDescription")" />
    <meta property="og:image" content="@Url.Content($"~/themes/{themeFolder}/og-image.jpg")" />

    <title>@ViewData["Title"] - @(tenant?.SiteName ?? "AI Relief")</title>

    <link rel="icon" href="~/themes/@(themeFolder)/favicon.ico" />
    <link rel="manifest" href="/manifest.json">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/signup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/themes/@(themeFolder)/theme.css" asp-append-version="true" />
    @if (hasGroupTheme)
    {
        <style>
            :root {
                @if (!string.IsNullOrWhiteSpace(layoutPrimary))
                {
                    @:--group-primary: @layoutPrimary;
                }
                @if (!string.IsNullOrWhiteSpace(layoutSecondary))
                {
                    @:--group-secondary: @layoutSecondary;
                }
            }
            body { background-image: linear-gradient(160deg, color-mix(in srgb, var(--group-primary, transparent) 8%, transparent) 0%, color-mix(in srgb, var(--group-secondary, transparent) 8%, transparent) 100%); }
            .navbar { border-bottom-color: var(--group-primary) !important; }
            .container { border-color: color-mix(in srgb, var(--group-primary, var(--border-color)) 40%, var(--border-color)) !important; }
            .admin-card { border-color: color-mix(in srgb, var(--group-secondary, var(--border-color)) 40%, var(--border-color)) !important; }
            .admin-card:hover { border-color: var(--group-primary) !important; box-shadow: 0 8px 20px color-mix(in srgb, var(--group-primary) 20%, transparent) !important; }
        </style>
    }
</head>
<body class="d-flex flex-column min-vh-100">

<header>
    <nav class="navbar navbar-expand-lg site-navbar">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                @if (!string.IsNullOrWhiteSpace(layoutLogoUrl))
                {
                    <img src="@layoutLogoUrl" alt="@(layoutGroup?.Name ?? "Group") logo" style="height:28px;width:auto;object-fit:contain;border-radius:3px;" />
                }
                else if (themeFolder == "aicag")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                         stroke="var(--text-accent, #38bdf8)" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                        <circle cx="12" cy="4" r="1.5"/><circle cx="6" cy="10" r="1.5"/><circle cx="18" cy="10" r="1.5"/>
                        <circle cx="8" cy="17" r="1.5"/><circle cx="16" cy="17" r="1.5"/><circle cx="12" cy="12" r="2"/>
                        <line x1="12" y1="5.5" x2="12" y2="10"/><line x1="7.3" y1="10.7" x2="10.2" y2="11.5"/>
                        <line x1="16.7" y1="10.7" x2="13.8" y2="11.5"/><line x1="9.2" y1="16.2" x2="10.5" y2="13.5"/>
                        <line x1="14.8" y1="16.2" x2="13.5" y2="13.5"/><line x1="6" y1="11.5" x2="7.5" y2="16"/>
                        <line x1="18" y1="11.5" x2="16.5" y2="16"/>
                    </svg>
                }
                else if (themeFolder == "descanso")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                         stroke="var(--text-accent, #8fbc5e)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="22" x2="12" y2="12"/>
                        <path d="M12 12 C8 12 5 9 7 6 C5 5 6 2 9 2 C10 0.5 14 0.5 15 2 C18 2 19 5 17 6 C19 9 16 12 12 12Z"/>
                        <line x1="9" y1="18" x2="12" y2="15"/><line x1="15" y1="18" x2="12" y2="15"/>
                    </svg>
                }
                @(tenant?.SiteName ?? "AI Relief")
            </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown"
                        aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="@L["ToggleNavigation"]">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNavDropdown">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="aboutDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @L["About"]
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="aboutDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="About">@L["AboutUs"]</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="CausalReasoning">@L["CausalReasoning"]</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="CognitiveReflection">@L["CognitiveReflection"]</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Metacognition">@L["Metacognition"]</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="ReadingComprehension">@L["ReadingComprehension"]</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="ShortTermMemory">@L["ShortTermMemory"]</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="ConfidenceCalibration">@L["ConfidenceCalibration"]</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">@L["Contact"]</a>
                        </li>

                        @if (layoutAppUser != null)
                        {
                            @if (layoutIsSystemAdmin)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="questionsDropdown" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        @L["Questions"]
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="questionsDropdown">
                                        <li><a class="dropdown-item" asp-controller="Questions" asp-action="Index">@L["ListQuestions"]</a></li>
                                        <li><a class="dropdown-item" asp-controller="Questions" asp-action="Create">@L["CreateNew"]</a></li>
                                    </ul>
                                </li>
                            }

                            @* Render admin nav partial that handles Group/System admin links based on app user level *@
                            <partial name="_AdminNavPartial" />

                            @if (!layoutIsSystemAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="MyQuestions">
                                        <i class="fas fa-history"></i> @L["MyQuestions"]
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    @* Inline login partial so tenant-mismatched users see anonymous buttons *@
                    <ul class="navbar-nav">
                    @if (layoutAppUser != null)
                    {
                        <li class="nav-item">
                            <a id="manage" class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">@L["HelloUser", layoutIdentityUser!.UserName]</a>
                        </li>
                        <li class="nav-item">
                            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button id="logout" type="submit" class="nav-link btn btn-link border-0">@L["Logout"]</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" id="signup" asp-controller="Signup" asp-action="Index">@L["SignUp"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="login" asp-area="Identity" asp-page="/Account/Login">@L["Login"]</a>
                        </li>
                    }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-fill py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <partial name="_GroupAdminWelcomePartial" />

    <footer class="site-footer py-3 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="small">@L["FooterCopyright", DateTime.Now.Year] @(tenant?.SiteName ?? "AI Relief")</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <button id="footer-theme-toggle" type="button" class="footer-theme-toggle" title="@L["ToggleTheme"]" data-light-mode-label="@lightModeLabel" data-dark-mode-label="@darkModeLabel">
                        <span class="theme-icon">@(htmlTheme == "dark" ? "☀️" : "🌙")</span>
                        <span class="theme-text">@(htmlTheme == "dark" ? lightModeLabel : darkModeLabel)</span>
                    </button>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>