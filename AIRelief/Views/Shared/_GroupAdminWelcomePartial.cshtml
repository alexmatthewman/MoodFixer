@inject IStringLocalizer<SharedGroupAdminWelcomeResource> L

@if (TempData["ShowGroupAdminWelcome"] != null)
{
    <div class="ga-welcome-overlay" id="gaWelcomeOverlay" onclick="if(event.target===this)this.remove()">
        <div class="ga-welcome-card">
            <h2><i class="fas fa-crown"></i> @L["WelcomeTitle"]</h2>
            <p>@L["WelcomeSubtitle"]</p>

            <ul class="ga-welcome-features">
                <li><i class="fas fa-check-circle"></i> @L["Feature_Lessons"]</li>
                <li><i class="fas fa-user-plus"></i> @Html.Raw(L["Feature_AddMembers"].Value)</li>
                <li><i class="fas fa-chart-bar"></i> @L["Feature_Statistics"]</li>
                <li><i class="fas fa-cog"></i> @L["Feature_Settings"]</li>
            </ul>

            <button class="btn btn-primary btn-lg" onclick="document.getElementById('gaWelcomeOverlay').remove()">
                <i class="fas fa-rocket"></i> @L["GetStarted"]
            </button>
        </div>
    </div>
}
