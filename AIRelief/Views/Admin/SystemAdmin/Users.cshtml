@model IList<AIRelief.Models.User>
@inject IStringLocalizer<AdminSystemAdminUsersResource> L
@{
    ViewData["Title"] = L["PageTitle"].Value;
    var currentUserId = (int)(ViewBag.CurrentUserId ?? 0);
}

<div class="admin-page">
<div class="admin-header">
    <h1 class="admin-title" style="margin: 0;">@L["UserManagement"]</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> @L["NoUsersFound"]
        </div>
    }
    else
    {
        <div class="admin-card">
            <div class="admin-card-header">
                <h5>@L["AllUsers", Model.Count]</h5>
            </div>
            <div class="admin-card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>@L["Name"]</th>
                                <th>@L["Email"]</th>
                                <th>@L["Group"]</th>
                                <th>@L["AuthLevel"]</th>
                                <th>@L["QueryFrequency"]</th>
                                <th>@L["Created"]</th>
                                <th>@L["LastQuestionAttempt"]</th>
                                <th>@L["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td><strong>@user.Name</strong></td>
                                    <td>@user.Email</td>
                                    <td>@(user.Group?.Name ?? "")</td>
                                    <td>
                                        <span class="badge bg-info">@user.AuthLevel</span>
                                    </td>
                                    <td>
                                        @if (user.GroupId != null)
                                        {
                                            <span class="text-muted">@user.Group?.QueryFrequency <small>(group)</small></span>
                                        }
                                        else
                                        {
                                            @(user.QueryFrequency.HasValue ? user.QueryFrequency.Value.ToString() : "—")
                                        }
                                    </td>
                                    <td>@user.CreatedDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(user.DatetimeOfLastQuestionAttempt.HasValue ? user.DatetimeOfLastQuestionAttempt.Value.ToString("dd MMM yyyy HH:mm") : L["Never"].Value)</td>
                                    <td class="action-cell">
                                        @if (user.ID == currentUserId)
                                        {
                                            <span class="badge bg-secondary">@L["CurrentUser"]</span>
                                        }
                                        else
                                        {
                                            <div class="d-flex gap-1 flex-wrap">
                                            <a href="/Admin/SystemAdmin/Users/Edit/@user.ID" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i> @L["Edit"]
                                            </a>
                                            @if (user.AuthLevel != AIRelief.Models.AuthLevel.SystemAdmin)
                                            {
                                                <a href="/Admin/SystemAdmin/Users/@user.ID/Questions" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-question-circle"></i> @L["Questions"]
                                                </a>
                                            }


                                            <form method="post" action="/Admin/SystemAdmin/Users/Remove/@user.ID" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('@Html.Raw(L["ConfirmDelete", user.Name.Replace("'", "\\'")].Value)');">
                                                    <i class="fas fa-user-minus"></i> @L["Delete"]
                                                </button>
                                            </form>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
