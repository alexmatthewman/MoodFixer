@inject IStringLocalizer<AdminSystemAdminManageSystemAdminsResource> L
@model IEnumerable<AIRelief.Models.User>
@{
    ViewData["Title"] = L["PageTitle"].Value;
    var currentUserId = (int)ViewBag.CurrentUserId;
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="admin-title" style="margin: 0;">@L["SystemAdministrators"]</h1>
        <a href="/Admin/SystemAdmin/SystemAdmins/Add" class="btn btn-primary">
            <i class="fas fa-user-plus"></i> @L["AddSystemAdmin"]
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@L["Close"]"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@L["Close"]"></button>
        </div>
    }

    <div class="admin-card">
        <div class="admin-card-header">
            <h5>@L["AllSystemAdmins", Model.Count()]</h5>
        </div>
        <div class="admin-card-body">
            @if (!Model.Any())
            {
                <p class="text-muted">@L["NoSystemAdmins"]</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>@L["Name"]</th>
                                <th>@L["Email"]</th>
                                <th>@L["Created"]</th>
                                <th>@L["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var admin in Model)
                            {
                                <tr>
                                    <td>@admin.Name</td>
                                    <td>@admin.Email</td>
                                    <td>@admin.CreatedDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (admin.ID == currentUserId)
                                        {
                                            <span class="badge bg-secondary">@L["CurrentUser"]</span>
                                        }
                                        else
                                        {
                                            <form method="post" action="/Admin/SystemAdmin/SystemAdmins/Remove/@admin.ID" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('@Html.Raw(L["ConfirmRemove", admin.Name].Value.Replace("'", "\\'"))');">
                                                    <i class="fas fa-user-minus"></i> @L["Remove"]
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
