@{
    ViewData["Title"] = "Bulk Question Management";

    var skippedRowsJson = TempData["CsvSkippedRowsJson"] as string;
    var skippedCsvContent = TempData["CsvSkippedContent"] as string;
    var importAdded   = TempData["CsvImportAdded"]   is int a ? a : (int?)null;
    var importSkipped = TempData["CsvImportSkipped"] is int s ? s : (int?)null;

    System.Collections.Generic.List<dynamic>? skippedRows = null;
    if (!string.IsNullOrEmpty(skippedRowsJson))
    {
        skippedRows = System.Text.Json.JsonSerializer.Deserialize<
            System.Collections.Generic.List<System.Text.Json.JsonElement>>(skippedRowsJson)
            ?.Select(e => (dynamic)e)
            .ToList();
    }
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="admin-title" style="margin: 0;">Bulk Question Management</h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (skippedRows != null && skippedRows.Count > 0)
    {
        <div class="admin-card mt-3 border-warning">
            <div class="admin-card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle"></i> @skippedRows.Count row(s) skipped — details below</h5>
                @if (!string.IsNullOrEmpty(skippedCsvContent))
                {
                    <form method="post" action="/Admin/SystemAdmin/BulkQuestions/DownloadSkippedCsv">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="csvContent" value="@skippedCsvContent" />
                        <button type="submit" class="btn btn-sm btn-dark">
                            <i class="fas fa-file-csv"></i> Download skipped rows as CSV
                        </button>
                    </form>
                }
            </div>
            <div class="admin-card-body p-0">
                <div style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:70px;">Row</th>
                                <th>MainText (preview)</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Text.Json.JsonElement row in skippedRows)
                            {
                                <tr>
                                    <td class="text-center">@row.GetProperty("RowNumber").GetInt32()</td>
                                    <td class="text-truncate" style="max-width:300px;" title="@row.GetProperty("Preview").GetString()">
                                        @row.GetProperty("Preview").GetString()
                                    </td>
                                    <td class="text-danger">@row.GetProperty("Reason").GetString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="row g-4 mt-2">

        <div class="col-md-4">
            <div class="admin-card h-100">
                <div class="admin-card-header">
                    <h5><i class="fas fa-download"></i> Download All Questions</h5>
                </div>
                <div class="admin-card-body d-flex flex-column">
                    <p>Export every question currently in the database as a JSON or CSV file.</p>
                    <div class="mt-auto d-grid gap-2">
                        <a href="/Admin/SystemAdmin/BulkQuestions/Download"
                           class="btn btn-primary w-100">
                            <i class="fas fa-file-code"></i> Download as JSON
                        </a>
                        <a href="/Admin/SystemAdmin/BulkQuestions/DownloadCsv"
                           class="btn btn-outline-primary w-100">
                            <i class="fas fa-file-csv"></i> Download as CSV
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card h-100">
                <div class="admin-card-header">
                    <h5><i class="fas fa-upload"></i> Upload Questions (JSON)</h5>
                </div>
                <div class="admin-card-body d-flex flex-column">
                    <p>Upload a JSON file to import questions. Items where <strong>MainText</strong> or <strong>QuestionText</strong> already exists in the database will be skipped.</p>
                    <form method="post" action="/Admin/SystemAdmin/BulkQuestions/Upload"
                          enctype="multipart/form-data" class="mt-auto">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <input type="file" name="file" accept=".json" class="form-control" required />
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-file-upload"></i> Upload JSON
                        </button>
                    </form>
                    <div class="mt-2">
                        <a href="/Admin/SystemAdmin/BulkQuestions/Template" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-file-code"></i> Download JSON Template
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card h-100">
                <div class="admin-card-header">
                    <h5><i class="fas fa-upload"></i> Upload Questions (CSV)</h5>
                </div>
                <div class="admin-card-body d-flex flex-column">
                    <p>Upload a CSV file to import questions. <mark><strong>Commas inside field values must be wrapped in quotes.</strong></mark> Items where <strong>MainText</strong> or <strong>QuestionText</strong> already exists in the database will be skipped.</p>
                    <form method="post" action="/Admin/SystemAdmin/BulkQuestions/UploadCsv"
                          enctype="multipart/form-data" class="mt-auto">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <input type="file" name="file" accept=".csv" class="form-control" required />
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-file-upload"></i> Upload CSV
                        </button>
                    </form>
                    <div class="mt-2">
                        <a href="/Admin/SystemAdmin/BulkQuestions/TemplateCsv" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-file-csv"></i> Download CSV Template
                        </a>
                        <div class="mt-2 small text-muted">
                            <p class="mb-1"><i class="fas fa-info-circle"></i> <strong>Opening the CSV template:</strong> Open the file in a plain text editor (e.g. Notepad on Windows, TextEdit on Mac) to see the double-quote characters that wrap fields containing commas. Excel hides these quotes and may strip them on save.</p>
                            <p class="mb-0"><i class="fas fa-table"></i> <strong>Editing in Excel:</strong> If you need to include a comma inside a cell, simply type the value normally&mdash;Excel will automatically add the surrounding quotes when you <em>Save As &rarr; CSV UTF-8 (Comma delimited)</em>. Do not manually type the quotes in Excel; let Excel handle the escaping.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>



    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="admin-card h-100 border-danger">
                <div class="admin-card-header bg-danger text-white">
                    <h5><i class="fas fa-trash-alt"></i> Remove All Questions</h5>
                </div>
                <div class="admin-card-body d-flex flex-column">
                    <p>Permanently delete every question from the database. A full JSON backup will be downloaded automatically before deletion.</p>
                    <div class="mt-auto">
                        <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#removeAllModal">
                            <i class="fas fa-trash-alt"></i> Remove All Questions
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="removeAllModal" tabindex="-1" aria-labelledby="removeAllModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="removeAllModalLabel"><i class="fas fa-exclamation-triangle"></i> Are you sure?</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>This will <strong>permanently delete all questions</strong> from the database.</p>
                    <p>A JSON backup of all questions will be downloaded to your computer before deletion.</p>
                    <p class="text-danger mb-0"><strong>This action cannot be undone.</strong></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" action="/Admin/SystemAdmin/BulkQuestions/RemoveAll">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt"></i> Yes, delete all and download backup
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
