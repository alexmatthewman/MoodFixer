@inject IStringLocalizer<AdminGroupAdminDetailsResource> L
@model AIRelief.Models.User
@{
    ViewData["Title"] = L["PageTitle"].Value;
    var statistics = ViewBag.Statistics as IList<AIRelief.Models.UserStatistics>;
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="admin-title" style="margin: 0;">@Model.Name</h1>
        <a href="/Admin/GroupAdmin/Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> @L["BackToUsers"]
        </a>
    </div>

    <div class="admin-card">
        <div class="admin-card-header">
            <h5>@L["UserInformation"]</h5>
        </div>
        <div class="admin-card-body">
            <div class="user-summary">
                <div class="user-name">
                    <strong>@Model.Name</strong>
                </div>
                <div class="user-email">
                    @Model.Email
                </div>
                <div class="user-stats">
                    <span class="stat-badge">@L["AuthLevel"]: @Model.AuthLevel</span>
                    <span class="stat-badge">@L["Created"]: @Model.CreatedDate.ToString("yyyy-MM-dd")</span>
                    <span class="stat-badge">@L["LastQuestionAttempt"]: @(Model.DatetimeOfLastQuestionAttempt.HasValue ? Model.DatetimeOfLastQuestionAttempt.Value.ToString("dd MMM yyyy HH:mm") : L["Never"].Value)</span>
                </div>
            </div>
        </div>
    </div>

    @if (statistics != null && statistics.Count > 0)
    {
        <div class="admin-card">
            <div class="admin-card-header">
                <h5>@L["UserStatistics"]</h5>
            </div>
            <div class="admin-card-body">
                @foreach (var stat in statistics)
                {
                    <div class="domain-stats">
                        <div class="stat-box">
                            <div class="stat-label">@L["CognitiveReflection"]</div>
                            <div class="stat-value">@stat.CognitiveReflectionWeightedAverage%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">@L["ReadingComprehension"]</div>
                            <div class="stat-value">@stat.ReadingComprehensionWeightedAverage%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">@L["CausalReasoning"]</div>
                            <div class="stat-value">@stat.CausalReasoningWeightedAverage%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">@L["Metacognition"]</div>
                            <div class="stat-value">@stat.MetacognitionWeightedAverage%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">@L["ShortTermMemory"]</div>
                            <div class="stat-value">@stat.ShortTermMemoryWeightedAverage%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">@L["ConfidenceCalibration"]</div>
                            <div class="stat-value">@stat.ConfidenceCalibrationWeightedAverage%</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
